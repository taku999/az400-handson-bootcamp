# AZ-400 ハンズオン用 .gitignore

# Azure
*.parameters.local.json
local.settings.json
__blobstorage__
__queuestorage__
__azurite_db*__.json

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# Environment variables
.env.*.local
*.secrets.json
*.secrets.*.json
.env
.env.local
.env.production
.env.development
**/appsettings.Development.json

# Logs
logs/
*.log

# バックアップファイル
*.bak
*.backup

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Build outputs
dist/
build/
*.js.map

# Test coverage
coverage/
*.coverage

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Secrets (絶対にコミットしない)
*.key
*.pem
*.pfx
secrets.yaml
secrets.json
